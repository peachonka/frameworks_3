{
  "App": {
    "Mode": "Production",
    "AllowedOrigins": [
      "https://myapp.com",
      "https://api.myapp.com"
    ],
    "RateLimit": {
      "RequestsPerMinute": 100,
      "BurstLimit": 20
    },
    "EnableRequestLogging": false,
    "MaxNoteLength": 5000
  },
  "Logging": {
    "LogLevel": {
      "Default": "Error",
      "Microsoft.AspNetCore": "Error"
    }
  }
}